        <mxCell id="e-workerhealth-call" value="7. GET CONVERSION_WORKER_URL + /health&#10;(the one real HTTP call app -&gt; worker)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;fontStyle=1;strokeColor=#82b366;exitX=0.7;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="api-worker-health" target="worker-legacy-health">
