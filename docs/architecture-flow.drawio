        </mxCell>

        <mxCell id="worker-poll" value="Poll loop&#10;claimNextQueuedJob() -&gt; processQueuedJob()&#10;every CONVERSION_WORKER_POLL_INTERVAL_MS (default 5000ms)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
