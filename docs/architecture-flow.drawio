            </Array>
          </mxGeometry>
        </mxCell>

        <!-- convert verifies payment against order (signature check) -->
        <mxCell id="e-convert-paymentcheck" value="verifies Razorpay signature +&#10;looks up ConversionOrder&#10;(if not free tier)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;dashed=1;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" parent="1" source="api-convert" target="api-create-order">
          <mxGeometry relative="1" as="geometry" />
