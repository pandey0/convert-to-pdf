          <mxGeometry x="760" y="850" width="280" height="70" as="geometry" />
        </mxCell>

        <mxCell id="worker-retry-note" value="On failure: attempts &lt; CONVERSION_WORKER_MAX_ATTEMPTS (default 3)&#10;-&gt; requeue with exponential backoff (CONVERSION_WORKER_RETRY_BASE_DELAY_MS);&#10;else -&gt; status=failed" style="text;html=1;align=left;fontSize=10;fontColor=#555555;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1070" y="845" width="400" height="60" as="geometry" />
        </mxCell>

        <mxCell id="worker-legacy-group" value="Legacy / internal-only HTTP endpoints (not used by the main job-queue flow)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;verticalAlign=top;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
