        <mxCell id="worker-group" value="Docker container: worker (Node.js, port 4000 internal)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=16;spacingTop=8;align=center;" vertex="1" parent="1">
