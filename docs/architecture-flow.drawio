        <mxCell id="e-createorder-razorpaylib" value="creates Razorpay order" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;fontStyle=1;exitX=0.8;exitY=1;entryX=0.5;entryY=0;strokeColor=#d79b00;" edge="1" parent="1" source="api-create-order" target="lib-razorpay">
