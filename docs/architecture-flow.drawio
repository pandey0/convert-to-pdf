        <mxCell id="e-geo-ipapi" value="GET https://ipapi.co/&lt;ip&gt;/json/" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;fontStyle=1;strokeColor=#d79b00;exitX=1;exitY=0.3;entryX=0;entryY=0.7;" edge="1" parent="1" source="lib-geo" target="ext-ipapi">
