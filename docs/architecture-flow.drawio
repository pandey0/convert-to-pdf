        <!-- /api/convert flow -->
        <mxCell id="e-convert-ratelimit" value="2a. rate limit&#10;10 / 60s per IP hash" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="api-convert" target="lib-rate-limit">
