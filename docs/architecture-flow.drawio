        <mxCell id="e-createorder-geo" value="checks isUserInIndia()&#10;for INR vs USD pricing" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;fontStyle=1;exitX=0.6;exitY=1;entryX=0.3;entryY=0;strokeColor=#d79b00;" edge="1" parent="1" source="api-create-order" target="lib-geo">
