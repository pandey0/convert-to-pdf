# Local/shared database value.
# The dev Docker compose file overrides this with its local Postgres service.
DATABASE_URL="postgresql://postgres:postgres@db:5432/convert_to_pdf?schema=public"

# Get from Razorpay Dashboard -> Accounts & Settings -> API Keys
RAZORPAY_KEY_ID="rzp_test_YOUR_KEY_HERE"
RAZORPAY_KEY_SECRET="YOUR_SECRET_HERE"

# This must match the public Razorpay key for the frontend.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_YOUR_KEY_HERE"

# Get from CloudConvert Dashboard -> Authorization -> API Keys
CLOUDCONVERT_API_KEY="YOUR_CLOUD_CONVERT_KEY_HERE"
NEXT_PUBLIC_SKIP_PAYMENT=true
