// This is your Prisma schema file for local development using SQLite
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ConversionOrder {
  id              String   @id @default(uuid())
  razorpayOrderId String   @unique
  status          String   @default("created") // "created", "paid", "completed", "failed"
  amount          Int?     // Stored in smallest currency unit (paise/cents)
  currency        String?  // INR or USD
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserUsage {
  id        String   @id @default(uuid())
  ipHash    String   @unique
  usedFree  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
