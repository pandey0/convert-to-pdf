# Production database.
# Paste your Neon Postgres connection string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Get from Razorpay Dashboard -> Accounts & Settings -> API Keys
RAZORPAY_KEY_ID="rzp_live_YOUR_KEY_HERE"
RAZORPAY_KEY_SECRET="YOUR_SECRET_HERE"

# IMPORTANT: Use the live public key in production.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_YOUR_KEY_HERE"

# Get from CloudConvert Dashboard -> Authorization -> API Keys
CLOUDCONVERT_API_KEY="YOUR_CLOUD_CONVERT_KEY_HERE"
NEXT_PUBLIC_SKIP_PAYMENT=false
