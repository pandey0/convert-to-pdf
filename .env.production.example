# Production database.
# Paste your Neon Postgres connection string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Conversion worker URL used by the app container.
CONVERSION_WORKER_URL="http://worker:4000/convert"
CONVERSION_WORKER_TOKEN="replace-with-a-long-random-token"
CONVERSION_WORKER_POLL_INTERVAL_MS=5000
CONVERSION_WORKER_MAX_ATTEMPTS=3
CONVERSION_WORKER_RETRY_BASE_DELAY_MS=5000
JOB_STORAGE_ROOT="/data/job-artifacts"
DELETE_JOB_OUTPUT_AFTER_DOWNLOAD=false
ADMIN_ACCESS_TOKEN="replace-with-a-long-random-admin-token"

# Get from Razorpay Dashboard -> Accounts & Settings -> API Keys
RAZORPAY_KEY_ID="rzp_live_YOUR_KEY_HERE"
RAZORPAY_KEY_SECRET="YOUR_SECRET_HERE"

# IMPORTANT: Use the live public key in production.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_YOUR_KEY_HERE"

# Get from CloudConvert Dashboard -> Authorization -> API Keys
CLOUDCONVERT_API_KEY="YOUR_CLOUD_CONVERT_KEY_HERE"
NEXT_PUBLIC_SKIP_PAYMENT=false

# Set to true because production should sit behind Caddy or Nginx.
TRUST_PROXY_HEADERS=true
